<Window x:Class="LilAgents.Windows.UI.PopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LilAgents.Windows.UI"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        ResizeMode="NoResize"
        Width="420"
        Height="310"
        MinWidth="420"
        MinHeight="310"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="TitleIconHoverBrush" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="TitleIconPressedBrush" Color="#30FFFFFF"/>
        <Style x:Key="TitleIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource TitleIconHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource TitleIconPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border x:Name="MainBorder"
            CornerRadius="12"
            BorderThickness="1"
            Margin="0">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="18" Opacity="0.35" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Provider Name + Dropdown -->
                    <Border Grid.Column="0"
                            Background="Transparent"
                            VerticalAlignment="Stretch"
                            MouseLeftButtonDown="ProviderName_Click">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                            <TextBlock x:Name="ProviderNameText"
                                       Text="Claude"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Cursor="Hand"/>
                            <TextBlock Text=" ▾"
                                       VerticalAlignment="Center"
                                       Opacity="0.6"
                                       Cursor="Hand"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                        <Button x:Name="RefreshButton"
                                Style="{StaticResource TitleIconButtonStyle}"
                                Content="&#xE72C;"
                                ToolTip="New session"
                                Click="RefreshButton_Click"
                                Margin="0,0,4,0"/>
                        <Button x:Name="CopyButton"
                                Style="{StaticResource TitleIconButtonStyle}"
                                Content="&#xE8C8;"
                                ToolTip="Copy chat"
                                Click="CopyButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Separator -->
            <Border x:Name="Separator"
                    Grid.Row="1"
                    Height="1"/>

            <!-- Terminal -->
            <local:TerminalControl x:Name="Terminal"
                                   Grid.Row="2"/>
        </Grid>
    </Border>
</Window>
